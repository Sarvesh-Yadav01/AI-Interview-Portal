<%- include("../partials/header") %>

<section class="auth-shell">
  <div class="auth-card">
    <h1>Welcome back</h1>
    <p class="text-muted">Login to continue your interview practice.</p>
    <% if (typeof message !== "undefined" && message) { %><div class="alert alert-success"><%= message %></div><% } %>
    <% if (error) { %><div class="alert alert-danger"><%= error %></div><% } %>
    <form action="/auth/login" method="POST" class="vstack gap-3">
      <div>
        <label class="form-label">Email</label>
        <input class="form-control" type="email" name="email" required>
      </div>
      <div>
        <label class="form-label">Password</label>
        <input class="form-control" type="password" name="password" required>
      </div>
      <button class="btn btn-accent w-100" type="submit">Login</button>
    </form>
    <div class="d-flex justify-content-between gap-3 mt-3">
      <a href="/auth/register">Create an account</a>
      <a href="/auth/forgot-password">Forgot password?</a>
    </div>
  </div>
</section>

<%- include("../partials/footer") %>
