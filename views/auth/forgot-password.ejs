<%- include("../partials/header") %>

<section class="auth-shell">
  <div class="auth-card">
    <h1>Forgot password</h1>
    <p class="text-muted">Enter your email and we will send a reset OTP.</p>
    <% if (message) { %><div class="alert alert-success"><%= message %></div><% } %>
    <% if (error) { %><div class="alert alert-danger"><%= error %></div><% } %>
    <form action="/auth/forgot-password" method="POST" class="vstack gap-3">
      <div>
        <label class="form-label">Email</label>
        <input class="form-control" type="email" name="email" required>
      </div>
      <button class="btn btn-accent w-100" type="submit">Send Reset OTP</button>
    </form>
    <p class="mt-3 mb-0"><a href="/auth/login">Back to login</a></p>
  </div>
</section>

<%- include("../partials/footer") %>
