<%- include("../partials/header") %>

<section class="container py-5">
  <div class="result-head mb-4">
    <div>
      <p class="eyebrow mb-1"><%= result.category %></p>
      <h1 class="h2 mb-0">Performance Report</h1>
      <p class="text-muted mb-0"><%= result.role || "General Candidate" %> - <%= result.status === "terminated" ? "Terminated" : "Completed" %></p>
    </div>
    <div class="d-flex align-items-center gap-3">
      <% if (!adminView) { %>
        <a class="btn btn-outline-dark" href="/interview/result/<%= result._id %>/report">Download PDF</a>
      <% } %>
      <div class="result-score"><%= result.score %>%</div>
    </div>
  </div>

  <div class="content-panel mb-4">
    <h2 class="h5">AI Summary</h2>
    <p class="mb-0"><%= result.summary %></p>
  </div>

  <div class="content-panel mb-4">
    <h2 class="h5">Monitoring Snapshot</h2>
    <div class="row g-3">
      <div class="col-md-4"><span class="text-muted d-block">Webcam</span><strong><%= result.proctoringSummary && result.proctoringSummary.webcamEnabled ? "Enabled" : "Not captured" %></strong></div>
      <div class="col-md-4"><span class="text-muted d-block">Screen Share</span><strong><%= result.proctoringSummary && result.proctoringSummary.screenShareEnabled ? "Enabled" : "Not captured" %></strong></div>
      <div class="col-md-4"><span class="text-muted d-block">Security Events</span><strong><%= result.proctoringSummary ? result.proctoringSummary.eventCount : result.securityEvents.length %></strong></div>
    </div>
    <% if (result.voiceTranscript) { %>
      <hr>
      <h3 class="h6">Voice Transcript</h3>
      <p class="text-muted mb-0 transcript-preview"><%= result.voiceTranscript %></p>
    <% } %>
  </div>

  <% if (result.status === "completed") { %>
    <div class="content-panel mb-4">
      <% if (result.score >= 60) { %>
        <p class="mb-0 fw-semibold text-success">Candidate passed this round. Selection email is triggered when SMTP is configured.</p>
      <% } else { %>
        <p class="mb-0 fw-semibold text-danger">Candidate did not meet the 60% passing threshold.</p>
      <% } %>
      <div class="mt-3">
        <a class="btn btn-accent" href="/interview">Continue</a>
      </div>
    </div>
  <% } %>

  <div class="vstack gap-3">
    <% result.answers.forEach((item, index) => { %>
      <div class="question-panel">
        <div class="d-flex justify-content-between gap-3">
          <h2 class="h5"><%= index + 1 %>. <%= item.question %></h2>
          <span class="score-pill"><%= item.score %>%</span>
        </div>
        <p class="small text-muted mb-2"><%= item.type || "written" %> - <%= item.topic || result.category %> - <%= item.difficulty || "Moderate" %></p>
        <% if (item.type === "mcq") { %>
          <p class="text-muted mb-1">Selected: <%= item.answer || "No option selected." %></p>
          <p class="mb-2"><strong>Correct Answer:</strong> <%= item.correctAnswer %></p>
        <% } else { %>
          <p class="text-muted"><%= item.answer || "No answer submitted." %></p>
        <% } %>
        <p><strong>Feedback:</strong> <%= item.feedback %></p>
        <p class="mb-0"><strong>Tips:</strong> <%= item.tips.join(", ") %></p>
      </div>
    <% }) %>
  </div>
</section>

<%- include("../partials/footer") %>
