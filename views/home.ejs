<%- include("partials/header") %>

<section class="hero-band">
  <div class="container py-5">
    <div class="row align-items-center g-4">
      <div class="col-lg-7">
        <p class="eyebrow">AI-powered hiring platform</p>
        <h1 class="display-4 fw-bold mb-3">AI Interview Portal for Companies</h1>
        <p class="lead text-muted mb-4">
          Run structured candidate screening with voice interviews, webcam monitoring, and admin analytics.
        </p>
        <div class="d-flex flex-wrap gap-3">
          <a href="/auth/register" class="btn btn-accent btn-lg">Create Candidate Account</a>
          <a href="/auth/login" class="btn btn-outline-dark btn-lg">Login</a>
        </div>
      </div>
      <div class="col-lg-5">
        <div class="feature-panel">
          <div class="metric-row">
            <span>Interview Modules</span>
            <strong>6</strong>
          </div>
          <div class="metric-row">
            <span>Proctoring</span>
            <strong>Live</strong>
          </div>
          <div class="metric-row">
            <span>Admin Analytics</span>
            <strong>Ready</strong>
          </div>
          <div class="pulse-line"></div>
        </div>
      </div>
    </div>
  </div>
</section>

<section class="container py-5">
  <div class="row g-4">
    <div class="col-md-4">
      <div class="info-card">
        <h2>Screen</h2>
        <p>Run HR, aptitude, technical, and voice rounds with strict scoring.</p>
      </div>
    </div>
    <div class="col-md-4">
      <div class="info-card">
        <h2>Monitor</h2>
        <p>Require webcam and screen sharing, capture events, and terminate suspicious sessions automatically.</p>
      </div>
    </div>
    <div class="col-md-4">
      <div class="info-card">
        <h2>Decide</h2>
        <p>Review AI reports, candidate history, and admin-level hiring metrics.</p>
      </div>
    </div>
  </div>
</section>

<%- include("partials/footer") %>
